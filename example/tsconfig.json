{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "jsx": "react-native",
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "./src/*"
      ],
      "@/assets/*": [
        "./assets/*"
      ],
      "beautiful-snackbar": [
        "../src/index.ts"
      ],
      "react": [
        "node_modules/react",
        "node_modules/@types/react"
      ],
      "react-native": [
        "node_modules/react-native",
        "node_modules/@types/react-native"
      ]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    ".expo/types/**/*.ts",
    "expo-env.d.ts",
    "../src/**/*.ts",
    "../src/**/*.tsx"
  ]
}
